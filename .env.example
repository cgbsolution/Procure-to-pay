# Public base URL the browser uses to reach the Next.js BFF route handlers.
# In practice this is usually the app's own origin (same-origin /api/* calls).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Internal URL the BFF (app/api/*) uses to reach the FastAPI backend.
# This is server-only and never exposed to the browser.
BACKEND_INTERNAL_URL=http://localhost:8000
